{
  "manifest_version": 3,
  "name": "Project Auto Login & MFA",
  "version": "1.0",
  "description": "Automates login and MFA retrieval for Visitador and other projects.",
  "icons": {
    "16": "icon_fast_login.png",
    "48": "icon_fast_login.png",
    "128": "icon_fast_login.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Project Auto Login"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}